# Domain for Caddy HTTPS (e.g. tabletop.example.com)
# Use "localhost" for local testing without SSL
DOMAIN=localhost

# PostgreSQL
POSTGRES_DB=tabletophelper
POSTGRES_USER=tabletophelper
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password

# JWT signing secret (min 64 chars, generate with: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# CORS (leave empty when Caddy proxies everything on the same domain)
CORS_ALLOWED_ORIGINS=
